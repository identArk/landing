# IdentArk Landing Page Environment Configuration
# Copy this file to .env.local and fill in the values

# ── Web3Forms Contact Form ───────────────────────────────────────────────────
# Get your access key from https://web3forms.com/
# Required for the contact form to function
VITE_WEB3FORMS_KEY=your-web3forms-access-key-here

# ── Analytics (Optional) ─────────────────────────────────────────────────────
# Google Analytics 4 Measurement ID (optional)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Enable/disable beta signup features
# VITE_BETA_SIGNUP_ENABLED=true

# ── API Configuration ─────────────────────────────────────────────────────────
# Base URL for API calls (if needed for dynamic content)
# VITE_API_BASE_URL=https://api.identark.io
